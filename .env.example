# Database — SQLite for local dev
# On Vercel: DB features (bookmarks/history/comments) are gracefully disabled
# To enable on Vercel: Add Neon Postgres and set DATABASE_URL
DATABASE_URL="file:./dev.db"

# TMDB API Key (v3) — get from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# TMDB API Read Access Token (v4 Bearer)
TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token_here

# ── Cloudflare Workers ──
# Main proxy (video streams + m3u8 + segments) — handles ALL streams
# Deploy: worker/luffytv-proxy.js → Cloudflare Worker named "luffytv-proxy"
NEXT_PUBLIC_PROXY_BASE=https://luffytv-proxy.ggy892767.workers.dev

# Subtitle proxy (DEDICATED — .vtt/.srt/.ass only) — handles subtitle fetching
# + SRT→VTT conversion + ASS→VTT conversion + correct Referer per CDN
# Deploy: worker/luffytv-subs.js → Cloudflare Worker named "luffytv-subs"
# If not set, falls back to /api/stream (Vercel route, same conversion logic)
# DEPLOYED: https://luffytv-subtitle.ggy892767.workers.dev
NEXT_PUBLIC_SUBS_PROXY_BASE=https://luffytv-subtitle.ggy892767.workers.dev
