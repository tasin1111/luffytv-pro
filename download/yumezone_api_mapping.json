{
  "site": "https://yumezone.live",
  "architecture": {
    "frontend": "Next.js (React Server Components) with tRPC",
    "backend": "Flask (Python) with UnifiedScraper",
    "database": "MongoDB (users, watchlist, comments, episode_reactions)",
    "video_proxy": {
      "cdn_eu": "https://cdn-eu.1ani.me/proxy/m3u8 (for arc/jet/zoro/subtitles)",
      "kiwi_worker": "WORKER_URL/p/ (Base64 payload for kiwi/animex providers)"
    }
  },
  "api_endpoints": {
    "yumezone_trpc": {
      "base": "https://yumezone.live/api/trpc",
      "format": "batch GET: ?batch=1&input={encoded_json} / batch POST with JSON body",
      "headers": {
        "Origin": "https://yumezone.live",
        "Referer": "https://yumezone.live/",
        "Accept": "application/json"
      },
      "procedures": {
        "anime.search": {
          "method": "GET",
          "params": {
            "q": "string",
            "page": "int"
          },
          "returns": "list of anime with id, anilistId, name, poster, episodes, type, rating"
        },
        "anime.getFullInfo": {
          "method": "GET",
          "params": {
            "id": "string (AniList ID)"
          },
          "returns": "full anime data: anilistId, malId, title, poster, banner, description, status, genres, studios, characters, seasons, etc."
        },
        "anime.getEpisodes": {
          "method": "GET",
          "params": {
            "id": "string (AniList ID)"
          },
          "returns": "episodes list + providers_map with episode IDs per provider (the ADDLIST mapping)"
        },
        "anime.getSources": {
          "method": "POST",
          "params": {
            "anime_id": "string",
            "episode_number": "int"
          },
          "returns": "streaming sources: m3u8/hls URLs, embed URLs, mp4 URLs, subtitles, intro/outro"
        },
        "anime.getWatchOrder": {
          "method": "GET",
          "params": {
            "id": "string (AniList ID)"
          },
          "returns": "watch order for sequels/prequels"
        },
        "anime.getNextAiring": {
          "method": "GET",
          "params": {
            "id": "string (AniList ID)"
          },
          "returns": "next airing episode info"
        },
        "anime.getThemes": {
          "method": "GET",
          "params": {
            "id": "string (AniList ID)"
          },
          "returns": "opening/ending themes"
        },
        "comments.getComments": {
          "method": "GET",
          "params": {
            "anime_id": "string",
            "episode_number": "int",
            "media_type": "anime",
            "page": "int",
            "limit": "int"
          }
        },
        "comments.getEpisodeReaction": {
          "method": "GET",
          "params": {
            "anime_id": "string",
            "episode_number": "int"
          }
        }
      }
    },
    "miruro_native": {
      "base": "https://api.miruro.tv (or configurable API_URL)",
      "headers": {
        "x-api-key": "API_KEY from env",
        "Origin": "first entry from ALLOWED_ORIGINS"
      },
      "endpoints": {
        "GET /search": {
          "params": {
            "q": "query",
            "page": "page number"
          }
        },
        "GET /anime/info": {
          "params": {
            "id": "AniList ID"
          }
        },
        "GET /episodes/{anilistId}": "Returns providers with episode IDs",
        "GET /watch/{provider}/{anilistId}/{category}/{slug}": "Returns streaming sources",
        "GET /sources": {
          "params": {
            "episodeId": "id",
            "provider": "name",
            "category": "sub|dub",
            "anilistId": "optional"
          }
        },
        "GET /home": "Home page data",
        "GET /genre/{name}": "Genre listing",
        "GET /schedule": "Airing schedule"
      }
    },
    "allanime_zenith": {
      "base": "https://api.allanime.day",
      "headers": {
        "Referer": "https://allmanga.to",
        "Origin": "https://allmanga.to"
      },
      "method": "GraphQL POST to /api",
      "encryption": "AES-CTR with SHA256 key from 'Xot36i3lK3:v1'",
      "persisted_query_hash": "d405d0edd690624b66baba3068e0edc3ac90f1597d898a1ec8db4e5c43c00fec",
      "provides": "MP4 streams (repackager.wixmp.com, fast4speed.rsvp, filemoon)"
    },
    "animex": {
      "graphql": "https://graphql.animex.one/graphql",
      "rest": "https://pp.animex.one/rest/api",
      "headers": {
        "Origin": "https://animex.one",
        "Referer": "https://animex.one/"
      },
      "mapping_query": "query($id:Int){anime(anilistId:$id){id anilistId titleEnglish titleRomaji}}",
      "endpoints": {
        "GET /rest/api/servers": {
          "params": {
            "id": "slug",
            "epNum": "episode number"
          }
        },
        "GET /rest/api/sources": {
          "params": {
            "id": "slug",
            "epNum": "episode",
            "type": "sub|dub",
            "providerId": "server id"
          }
        },
        "GET /rest/api/episodes": {
          "params": {
            "id": "slug"
          }
        }
      },
      "provides": "HLS streams with multiple sub-servers (uwu, mochi, kami, beep, etc.)"
    }
  },
  "content_providers": {
    "zenith": {
      "type": "AllAnime",
      "stream_format": "MP4",
      "capabilities": {
        "hls": false,
        "embed": false,
        "mp4": true
      },
      "episode_id_format": "watch/zenith/{anilist_id}/sub/zenith-{ep_num}",
      "proxy": "None (direct URLs)"
    },
    "kiwi": {
      "type": "Miruro/Kiw/AnimePahe",
      "stream_format": "HLS m3u8 + embed",
      "capabilities": {
        "hls": true,
        "embed": true
      },
      "episode_id_format": "watch/kiwi/{anilist_id}/sub/{slug}",
      "proxy": "Kiwi worker (Base64 payload) or CDN-EU",
      "referer": "https://kwik.cx/"
    },
    "ax-mimi": {
      "type": "AnimeX sub-server",
      "stream_format": "HLS m3u8",
      "capabilities": {
        "hls": true,
        "embed": false
      }
    },
    "ax-wave": {
      "type": "AnimeX sub-server",
      "stream_format": "HLS m3u8",
      "capabilities": {
        "hls": true,
        "embed": false
      }
    },
    "ax-shiro": {
      "type": "AnimeX sub-server",
      "stream_format": "HLS m3u8",
      "capabilities": {
        "hls": true,
        "embed": false
      }
    },
    "ax-yuki": {
      "type": "AnimeX sub-server",
      "stream_format": "HLS m3u8",
      "capabilities": {
        "hls": true,
        "embed": false
      }
    },
    "ax-zen": {
      "type": "AnimeX sub-server",
      "stream_format": "HLS m3u8",
      "capabilities": {
        "hls": true,
        "embed": false
      }
    },
    "ax-beep": {
      "type": "AnimeX sub-server",
      "stream_format": "HLS m3u8",
      "capabilities": {
        "hls": true,
        "embed": false
      }
    },
    "bee": {
      "type": "Miruro/Bee",
      "stream_format": "HLS m3u8",
      "capabilities": {
        "hls": true,
        "embed": false
      }
    },
    "zoro": {
      "type": "Megaplay embed",
      "stream_format": "Embed only",
      "capabilities": {
        "hls": false,
        "embed": true
      },
      "embed_url_format": "https://megaplay.buzz/stream/ani/{anilist_id}/{ep_num}/{sub|dub}",
      "proxy": "CDN-EU"
    },
    "anixtv": {
      "type": "AnixTv Hindi embed",
      "stream_format": "Embed only",
      "capabilities": {
        "hls": false,
        "embed": true
      },
      "embed_url_format": "https://anixtv.in/anime-watch?action=hindi_1_player&id={anilist_id}&season=1&episode={ep_num}"
    }
  },
  "provider_priority": [
    "zenith",
    "kiwi",
    "ax-mimi",
    "ax-wave",
    "ax-shiro",
    "ax-yuki",
    "ax-zen",
    "ax-beep",
    "bee",
    "zoro",
    "anixtv"
  ],
  "anime_id_system": {
    "primary_id": "AniList ID (integer, used as string in API)",
    "search_returns": "id (same as anilistId) + anilistId",
    "episode_id_formats": {
      "miruro": "watch/{provider}/{anilist_id}/{category}/{slug}",
      "zenith": "watch/zenith/{anilist_id}/{category}/zenith-{ep_num}",
      "animex": "watch/ax/{anilist_id}/{category}/{server_id}-{ep_num}",
      "zoro": "Uses anilist_id + ep_number directly (no slug)",
      "anixtv": "Uses anilist_id + ep_number directly"
    }
  },
  "m3u8_headers": {
    "kiwi": {
      "Referer": "https://kwik.cx/"
    },
    "animex": {
      "Referer": "(from upstream headers in /sources response)"
    },
    "arc": {
      "Referer": "(proxied through CDN-EU)"
    },
    "jet": {
      "Referer": "(proxied through CDN-EU)"
    },
    "zoro": {
      "Referer": "https://megaup.nl/ (proxied through CDN-EU)"
    },
    "zenith": "No special headers (direct MP4 URLs)"
  },
  "proxy_routing": {
    "rule": "kiwi/animex/ax-* -> kiwi worker (/p/ Base64); arc/jet/zoro/subtitles -> CDN-EU proxy; zenith -> no proxy",
    "cdn_eu_format": "https://cdn-eu.1ani.me/proxy/m3u8?url={encoded_url}&headers={encoded_headers}",
    "worker_format": "WORKER_URL/p/{base64(url + null_byte + referer)}"
  }
}